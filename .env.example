# LLM provider — pick one block and fill in your credentials

# Option 1: Anthropic direct
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OpenRouter (supports Claude + other models)
# PACT_LLM_BASE_URL=https://openrouter.ai/api
# PACT_LLM_API_KEY=sk-or-...
# PACT_LLM_MODEL=anthropic/claude-sonnet-4-5

# Option 3: Bonsai proxy
# ANTHROPIC_BASE_URL=https://go.trybons.ai
# ANTHROPIC_AUTH_TOKEN=sk_cr_...
