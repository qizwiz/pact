{
  "name": "pact",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.foundry/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "JuanBlanco.solidity"]
    }
  }
}
