# corpus JSONL files can be large — don't track in git
corpus/*.jsonl
# but DO track the batch rotation pointer
!corpus/batch_state.txt

# TLC model checker artifacts
docs/tla/*.bin
docs/tla/states/
docs/tla/*_TTrace_*.tla
# TLC jar (binary — download separately)
docs/tla/tla2tools.jar
# Pipeline-generated specs (ephemeral — regenerated each run)
docs/tla/generated/

# Loop runtime state and artifacts
.pact_loop/
.pact_oracle_baseline
heal_*.json
intent*.json
!intent_pact_self.json
pact_tool.egg-info/
graphify-out/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# Local credentials — never commit
.env
.pact_stages/
